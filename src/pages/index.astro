
---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Zoom 49 – Recursive Collaboration Lab">
  <section class="text-center space-y-6">
    <h1 class="text-5xl font-serif tracking-tight">Zoom 49</h1>
    <h2 class="text-xl text-neutral-600">Recursive Collaboration Lab</h2>
    <p class="max-w-xl mx-auto text-neutral-700">
      A serialized experimental platform exploring recursive coordination,
      emergent meaning, and network narratives.
    </p>
    <div class="space-x-4 pt-4">
      <a href="/weeks/" class="px-5 py-2 border border-neutral-900 hover:bg-neutral-900 hover:text-white transition">
        Explore Weeks
      </a>
      <a href="https://github.com/" class="px-5 py-2 border border-signal text-signal hover:bg-signal hover:text-white transition">
        View Repository
      </a>
    </div>
  </section>
</BaseLayout>
