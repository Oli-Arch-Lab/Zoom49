---
const { figure } = Astro.props;
---

<section class="mb-20">
  <div class="mb-6">
    <img
      src={figure.image}
      alt={figure.title}
      class="w-full rounded-lg border border-neutral-200"
    />
  </div>

  <h2 class="text-2xl font-serif mb-2">
    Figure {figure.id} — {figure.title}
  </h2>

  <p class="text-neutral-600 mb-4 italic">
    {figure.visual}
  </p>

  <div class="mb-4">
    <h3 class="font-semibold mb-2">Key Events</h3>
    <ul class="list-disc ml-6 space-y-1 text-neutral-700">
      {figure.keyEvents.map(event => (
        <li>{event}</li>
      ))}
    </ul>
  </div>

  <div class="mb-4">
    <h3 class="font-semibold mb-2">Character Arcs</h3>
    <ul class="ml-6 space-y-1 text-neutral-700">
      {Object.entries(figure.characterArcs).map(([name, role]) => (
        <li>
          <span class="font-medium">{name}:</span> {role}
        </li>
      ))}
    </ul>
  </div>

  <div class="flex flex-wrap gap-2 mt-4">
    {figure.motifs.map(motif => (
      <span class="px-3 py-1 text-xs border border-signal text-signal rounded-full">
        {motif}
      </span>
    ))}
  </div>

  <hr class="mt-10 border-neutral-200" />
</section>