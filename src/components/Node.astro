---
const { id, title, markdownFile, clusterId, color } = Astro.props;
import TooltipPanel from './TooltipPanel.astro';
---

<div class="node" style={`border-color:${color || '#4fc3f7'}`} id={id}>
  <div class="node-core pulse-animation">{title}</div>
  <TooltipPanel markdownFile={markdownFile} />
</div>

<style>
.node { 
  display: inline-block; 
  margin: 10px; 
  cursor: pointer; 
}
.node-core { 
  padding: 10px 20px; 
  border: 2px solid; 
  border-radius: 8px; 
  transition: transform 0.2s; 
}
.node-core:hover { 
  transform: scale(1.05); 
}
.pulse-animation {
  animation: pulse 2s infinite ease-in-out;
}
@keyframes pulse {
  0% { box-shadow: 0 0 0px rgba(79,195,247,0.7); }
  50% { box-shadow: 0 0 15px rgba(79,195,247,0.7); }
  100% { box-shadow: 0 0 0px rgba(79,195,247,0.7); }
}
</style>