---
const { figures } = Astro.props;
---

<div id="carousel-root" class="relative w-full isolate scroll-mt-20">

  <!-- Radio Inputs -->
  {figures.map((_, i) => (
    <input
      type="radio"
      name="carousel"
      id={`slide-${i}`}
      class="hidden"
      checked={i === 0}
    />
  ))}

  <!-- Slides -->
  <div class="slides relative overflow-hidden min-h-[600px]">

    {figures.map((figure, i) => (
      <div class="slide absolute inset-0 opacity-0 transition-opacity duration-500 pointer-events-none">

        <img
          src={figure.image}
          alt={figure.title}
          class="w-full rounded-lg border border-neutral-200 mb-6"
        />

        <h2 class="text-2xl font-serif mb-2">
          Figure {figure.id} — {figure.title}
        </h2>

        <p class="text-neutral-600 italic mb-6">
          {figure.visual}
        </p>

        <ul class="list-disc ml-6 mb-6 text-neutral-700">
          {figure.keyEvents.map(event => (
            <li>{event}</li>
          ))}
        </ul>

      </div>
    ))}

  </div>

  <!-- Navigation -->
  <div class="nav flex justify-between mt-8">

    <!-- Previous -->
    {figures.map((_, i) => {
      const prev = (i - 1 + figures.length) % figures.length;
      return (
        <label
          for={`slide-${prev}`}
          class="nav-btn prev hidden px-4 py-2 border border-neutral-300 hover:bg-neutral-100 cursor-pointer"
          data-index={i}
        >
          ← Previous
        </label>
      );
    })}

    <!-- Next -->
    {figures.map((_, i) => {
      const next = (i + 1) % figures.length;
      return (
        <label
          for={`slide-${next}`}
          class="nav-btn next hidden px-4 py-2 border border-neutral-300 hover:bg-neutral-100 cursor-pointer"
          data-index={i}
        >
          Next →
        </label>
      );
    })}

  </div>

  <!-- Dots -->
  <div class="flex justify-center gap-4 mt-10">
    {figures.map((_, i) => (
      <label
        for={`slide-${i}`}
        class="w-3 h-3 rounded-full bg-neutral-300 hover:bg-signal cursor-pointer transition"
      ></label>
    ))}
  </div>

</div>

<style>
  #carousel-root input:nth-of-type(1):checked ~ .slides > div:nth-child(1),
  #carousel-root input:nth-of-type(2):checked ~ .slides > div:nth-child(2),
  #carousel-root input:nth-of-type(3):checked ~ .slides > div:nth-child(3),
  #carousel-root input:nth-of-type(4):checked ~ .slides > div:nth-child(4),
  #carousel-root input:nth-of-type(5):checked ~ .slides > div:nth-child(5),
  #carousel-root input:nth-of-type(6):checked ~ .slides > div:nth-child(6),
  #carousel-root input:nth-of-type(7):checked ~ .slides > div:nth-child(7) {
    opacity: 1;
    position: relative;
    pointer-events: auto;
  }

  /* Navigation */
  #carousel-root input:nth-of-type(1):checked ~ .nav label[data-index="0"],
  #carousel-root input:nth-of-type(2):checked ~ .nav label[data-index="1"],
  #carousel-root input:nth-of-type(3):checked ~ .nav label[data-index="2"],
  #carousel-root input:nth-of-type(4):checked ~ .nav label[data-index="3"],
  #carousel-root input:nth-of-type(5):checked ~ .nav label[data-index="4"],
  #carousel-root input:nth-of-type(6):checked ~ .nav label[data-index="5"],
  #carousel-root input:nth-of-type(7):checked ~ .nav label[data-index="6"] {
    display: inline-block;
  }

  .slide {
    height: 100%;
  }
</style>